# Конфигурация запуска стенда. Скопировать в .env и заполнить реальными
# значениями. .env в git НЕ коммитится (см. .gitignore) — секреты живут
# только локально на машине развёртывания.

# qBittorrent (без ST_QBIT_URL модуль torrents не стартует)
ST_QBIT_URL=http://127.0.0.1:8080
ST_QBIT_USER=admin
ST_QBIT_PASS=

# Вход в веб-интерфейс (docs/security.md, Этап 1) — ОБЯЗАТЕЛЬНО:
# ключ подписи сессионной куки (длинная случайная строка; без него
# сессии слетают при рестарте). Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
ST_SECRET_KEY=
# Первичная учётка администратора (создаётся при первом старте, если
# учётки ещё нет). Пароль в БД хранится только хэшем.
ST_ADMIN_USER=admin
ST_ADMIN_PASSWORD=
# Secure-куки: true (по умолчанию) — кука только по https (за nginx с TLS).
# Для входа по http локально, до настройки nginx, временно: false.
# ST_COOKIE_SECURE=true
# Замок (требовать вход): true по умолчанию. Держать false, пока фронт не
# умеет логиниться (иначе текущий UI получит 401); включить вместе с
# готовым экраном входа. См. docs/security.md, Этап 1.
# ST_AUTH_REQUIRED=true

# Шифрование секретов в БД (Этап 3Б) — ОБЯЗАТЕЛЬНО для прода: стабильный
# ключ Fernet (при его смене секреты не расшифруются). Без него ключ
# выводится из ST_SECRET_KEY (тогда ротация ST_SECRET_KEY ломает секреты).
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ST_ENCRYPTION_KEY=
# /docs и /openapi.json (по умолчанию выключены в проде — Этап 4).
# Включить для генерации типов фронта (gen:api):
# ST_DOCS_ENABLED=true

# Необязательное:
# ST_DB_PATH=app.db   # по умолчанию app.db в каталоге проекта
# ST_LOG_DIR=logs
