# Конфигурация запуска стенда. Скопировать в .env и заполнить реальными
# значениями. .env в git НЕ коммитится (см. .gitignore) — секреты живут
# только локально на машине развёртывания.

# qBittorrent (без ST_QBIT_URL модуль torrents не стартует)
ST_QBIT_URL=http://127.0.0.1:8080
ST_QBIT_USER=admin
ST_QBIT_PASS=

# Необязательное:
# ST_DB_PATH=app.db   # по умолчанию app.db в каталоге проекта
# ST_LOG_DIR=logs
