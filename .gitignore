# Папка виртуального окружения
venv/
.venv/

# Кэш Python
__pycache__/
*.pyc

# Файлы с переменными окружения
.env

# Папки от IDE (на всякий случай)
.idea/
.vscode/

# База данных SQLite (включая WAL/SHM и любые бэкапы рядом с app.db)
*.db
app.db*
*.bak

# Папка тестов
test/
# Папка с торрентами
parser_dumps/
# Папка кодом страниц для дебага
torrent_cache/
debug_kinozal.py
vk_scraper_dumps/
logs/

# Telethon session (фаза 0, scripts/telegram_phase0)
scripts/telegram_phase0/*.session
scripts/telegram_phase0/*.session-journal
# Артефакты новой системы
.venv*/
logs/
tests/golden/
tests/fixtures/

# Локальные секреты — никогда не синхронизировать
docs/key.txt

# Лог запуска стенда (создаётся restart.sh)
uvicorn.log
